# Required: UniFi Cloud API Key (read-only)
# Obtain from https://unifi.ui.com → Settings → API
UNIFI_API_KEY=your-api-key-here

# Optional: Owner API Key for Cloud Connector access
# Required for /v1/connector/consoles/* endpoints (Local API proxy)
# Must be created by the console owner account
# UNIFI_API_KEY_OWNER=your-owner-api-key-here

# Optional: API base URL (default: https://api.ui.com/v1)
# UNIFI_API_URL=https://api.ui.com/v1

# --- Optional: Local controller (legacy API on LAN) ---
# Enables per-port error counters (rx_errors/tx_errors/dropped) and port flap events
# that the Cloud Connector / Integration API do not expose.
# Requires the host running this MCP to have LAN reachability to the controller.
# UNIFI_LOCAL_URL=https://10.10.1.1
# UNIFI_LOCAL_USER=readonly-user
# UNIFI_LOCAL_PASS=readonly-password
# UNIFI_LOCAL_SITE=default
# UNIFI_LOCAL_INSECURE=true  # accept self-signed cert (typical for UDM)
