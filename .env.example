# Required: UniFi Cloud API Key (read-only)
# Obtain from https://unifi.ui.com → Settings → API
UNIFI_API_KEY=your-api-key-here

# Optional: Owner API Key for Cloud Connector access
# Required for /v1/connector/consoles/* endpoints (Local API proxy)
# Must be created by the console owner account
# UNIFI_API_KEY_OWNER=your-owner-api-key-here

# Optional: API base URL (default: https://api.ui.com/v1)
# UNIFI_API_URL=https://api.ui.com/v1
