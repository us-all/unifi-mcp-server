{
  "name": "@us-all/unifi-mcp",
  "version": "1.8.5",
  "description": "UniFi semantic analysis MCP server — fleet health, anomaly detection, cross-site analytics on top of Cloud API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "unifi-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/us-all/unifi-mcp-server.git"
  },
  "homepage": "https://github.com/us-all/unifi-mcp-server#readme",
  "bugs": "https://github.com/us-all/unifi-mcp-server/issues",
  "keywords": [
    "mcp",
    "unifi",
    "ubiquiti",
    "network",
    "monitoring",
    "model-context-protocol"
  ],
  "author": "us-all",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "presmoke": "pnpm run build",
    "smoke": "node scripts/smoke-test.mjs",
    "pretoken-stats": "pnpm run build",
    "token-stats": "node scripts/measure-tokens.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@us-all/mcp-toolkit": "^1.1.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
